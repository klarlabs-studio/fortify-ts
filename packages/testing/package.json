{
  "name": "@klarlabs-studio/fortify-testing",
  "version": "0.1.7",
  "description": "Chaos engineering testing utilities for Fortify resilience patterns",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@klarlabs-studio/fortify-core": "workspace:*"
  },
  "devDependencies": {
    "@klarlabs-studio/fortify-bulkhead": "workspace:*",
    "@klarlabs-studio/fortify-circuit-breaker": "workspace:*",
    "@klarlabs-studio/fortify-fallback": "workspace:*",
    "@klarlabs-studio/fortify-middleware": "workspace:*",
    "@klarlabs-studio/fortify-rate-limit": "workspace:*",
    "@klarlabs-studio/fortify-retry": "workspace:*",
    "@klarlabs-studio/fortify-timeout": "workspace:*",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/klarlabs-studio/fortify-ts.git",
    "directory": "packages/testing"
  },
  "homepage": "https://github.com/klarlabs-studio/fortify-ts/tree/main/packages/testing#readme",
  "bugs": {
    "url": "https://github.com/klarlabs-studio/fortify-ts/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "resilience",
    "testing",
    "chaos-engineering",
    "fortify"
  ],
  "license": "MIT",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
