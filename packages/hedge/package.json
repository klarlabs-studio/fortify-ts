{
  "name": "@klarlabs-studio/fortify-hedge",
  "version": "0.1.0",
  "description": "Hedged-request execution for tail-latency reduction in Fortify",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "dev": "tsup --watch",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@klarlabs-studio/fortify-core": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  },
  "peerDependencies": {
    "zod": "^4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/klarlabs-studio/fortify-ts.git",
    "directory": "packages/hedge"
  },
  "homepage": "https://github.com/klarlabs-studio/fortify-ts/tree/main/packages/hedge#readme",
  "bugs": {
    "url": "https://github.com/klarlabs-studio/fortify-ts/issues"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "hedge",
    "hedged-request",
    "tail-latency",
    "resilience"
  ],
  "license": "MIT",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
