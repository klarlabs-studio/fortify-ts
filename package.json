{
  "name": "@klarlabs-studio/fortify",
  "version": "0.0.0",
  "private": true,
  "description": "Production-grade resilience and fault-tolerance library for TypeScript",
  "repository": {
    "type": "git",
    "url": "https://github.com/klarlabs-studio/fortify-ts.git"
  },
  "license": "MIT",
  "author": "Felix Geelhaar",
  "type": "module",
  "scripts": {
    "build": "turbo build",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "clean": "turbo clean && rm -rf node_modules",
    "dev": "turbo dev",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:coverage": "turbo test:coverage",
    "typecheck": "turbo typecheck"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@types/node": "^24.13.2",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "^9.39.4",
    "fast-check": "4.8.0",
    "prettier": "^3.9.1",
    "tsup": "^8.5.1",
    "turbo": "^2.10.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "pnpm": {
    "overrides": {
      "vite": "7.3.2"
    }
  },
  "packageManager": "pnpm@9.14.4",
  "engines": {
    "node": ">=20.0.0"
  }
}
